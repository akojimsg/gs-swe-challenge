{
  // gs-swe-challenge dev container
  // Base image (no custom Dockerfile); tools layered via features + setup.sh
  "name": "gs-swe-challenge",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  // Prebuilt, well-maintained tooling
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // Make SDKMAN (Java/Gradle) discoverable to terminals AND VS Code extensions.
  // Node from nvm is exposed via symlinks created in setup.sh.
  "remoteEnv": {
    "SDKMAN_DIR": "/home/vscode/.sdkman",
    "NVM_DIR": "/home/vscode/.nvm",
    "JAVA_HOME": "/home/vscode/.sdkman/candidates/java/current",
    "PATH": "/home/vscode/.sdkman/candidates/java/current/bin:/home/vscode/.sdkman/candidates/gradle/current/bin:${containerEnv:PATH}"
  },

  // Provision SDKMAN + Java 21 + Gradle and nvm + Node LTS after the container is created
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "waitFor": "postCreateCommand",

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-boot-dev-pack",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "github.vscode-github-actions"
      ],
      "settings": {
        "java.jdt.ls.java.home": "/home/vscode/.sdkman/candidates/java/current",
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-21",
            "path": "/home/vscode/.sdkman/candidates/java/current",
            "default": true
          }
        ],
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  // Gateway, services, frontend, Grafana, Jaeger, Mailhog, Prometheus
  "forwardPorts": [8080, 8081, 8082, 8083, 8084, 8085, 3000, 3001, 16686, 8025, 9090],

  "remoteUser": "vscode"
}
