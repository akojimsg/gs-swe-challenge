# =============================================================================
# gs-swe-challenge — environment template
# Copy to .env and adjust. Never commit the real .env (it is gitignored).
# Hostnames (postgres, redis, mailhog) are Docker Compose service names.
# =============================================================================

# --- Spring -------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=docker

# --- PostgreSQL (single instance, 5 schemas) ----------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gsswec
POSTGRES_USER=gsswec
POSTGRES_PASSWORD=change_me_local_dev          # CHANGE in real .env

# --- Redis (cache + streams + rate limit + idempotency) -----------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                                  # empty = no auth (local only)

# --- JWT (HS256) --------------------------------------------------------------
# Generate a 256-bit base64 secret, e.g.: openssl rand -base64 32
JWT_SECRET=change_me_base64_256_bit_secret       # CHANGE in real .env
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# --- Mail (Mailhog, local SMTP) -----------------------------------------------
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=no-reply@gsswec.com

# --- Internal gRPC (Orders -> Products) ---------------------------------------
PRODUCTS_GRPC_HOST=products
PRODUCTS_GRPC_PORT=50051

# --- Service ports (host-exposed) ---------------------------------------------
GATEWAY_PORT=8080
USERS_PORT=8081
PRODUCTS_PORT=8082
ORDERS_PORT=8083
PAYMENTS_PORT=8084
NOTIFICATIONS_PORT=8085
FRONTEND_PORT=3000

# --- Observability ------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
JAEGER_UI_PORT=16686
MAILHOG_UI_PORT=8025

# --- Seed data (make seed) ----------------------------------------------------
SEED_ADMIN_EMAIL=admin@gsswec.com
SEED_ADMIN_PASSWORD=admin123
SEED_BUYER_EMAIL=buyer@gsswec.com
SEED_BUYER_PASSWORD=buyer123
