# Frontend env. Copy to .env.local for local dev (gitignored by Vite convention).
#
# The SPA talks ONLY to the Gateway REST surface. In dev, vite.config.js proxies
# /api -> VITE_PROXY_TARGET, so VITE_API_BASE_URL can stay a relative /api/v1.
# In a built image, nginx proxies /api -> the gateway (see nginx.conf).

# Relative base — works with both the dev proxy and the nginx prod proxy.
VITE_API_BASE_URL=/api/v1

# Dev-only: where the vite proxy forwards /api. Frontend lane gateway host port.
VITE_PROXY_TARGET=http://localhost:8110
