      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Products — CQRS: read model (Redis cache) vs write model (PostgreSQL)" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#26215C;" vertex="1" parent="1">
